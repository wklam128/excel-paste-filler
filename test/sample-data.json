  "example_custom_mapping": {
    "_comment": "Save this under the origin https://yoursite.com in the Options page → Field Mappings tab.",
    "origin": "http://localhost",
    "mappings": {
      "CustomerName": "#customer-name",
      "Company":      "input[name='Company']",
      "Email":        "input[name='Email']",
      "Phone":        "input[name='Phone']",
      "Product":      "select[name='Product']",
      "Quantity":     "input[name='Quantity']",
      "OrderDate":    "input[name='OrderDate']",
      "Country":      "select[name='Country']",
      "Priority":     "input[type='radio'][name='Priority']",
      "Address":      "textarea[name='Address']",
      "Notes":        "textarea[name='Notes']",
      "Newsletter":   "input[type='checkbox'][name='Newsletter']",
      "Terms":        "input[type='checkbox'][name='Terms']"
    }
  },

  "how_to_create_excel": {
    "step1": "Open Microsoft Excel or Google Sheets.",
    "step2": "Create a header row with the column names listed in 'excel_columns' above.",
    "step3": "Add data rows below the header (one order per row).",
    "step4": "Save as .xlsx format.",
    "step5": "Open the test form (test/sample-form.html) in Chrome with the extension loaded.",
    "step6": "Click the green 'Import Excel' button, upload the file, and follow the panel steps."
  }
}
